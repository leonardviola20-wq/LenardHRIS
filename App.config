<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<startup>
		<!-- Match this to your installed .NET Framework -->
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/>
	</startup>
	<connectionStrings>
		<add name="LenardHRDB"
			 connectionString="Data Source=(LocalDB)\MSSQLLocalDB;
                         AttachDbFilename=D:\VSProject\HRISLenard\LenardHRIS\Database\LenardHRDB.mdf;
                         Integrated Security=True;
                         Connect Timeout=30"
			 providerName="System.Data.SqlClient" />
	</connectionStrings>
</configuration>
